<header class="app-navbar">
  <div class="app-navbar__toolbar">

    <!-- Botón menu mobile -->
    <div class="app-navbar__menu-btn">
      <button class="icon-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar"
        aria-controls="appSidebar">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="4" cy="12" r="1" />
          <rect width="14" height="2" x="7" y="11" rx=".94" ry=".94" />
          <rect width="18" height="2" x="3" y="16" rx=".94" ry=".94" />
          <rect width="18" height="2" x="3" y="6" rx=".94" ry=".94" />
        </svg>
      </button>
    </div>

    <!-- Info -->
    <div class="app-navbar__info" id="Meta-informacion">
      <% if (session && session.user) { %>
      <span class="app-navbar__user">
        Asociado(a): <strong><%- session.user.nombreusuario %></strong>
      </span>
      <span class="app-navbar__meta">
          Hoy es <strong><%- formatFechaHoy(new Date()) %></strong> :
          Ultimo ingreso: <strong><%- formatUltimoIngreso(session.user.ultimoingreso) %></strong>
      </span>
      <% } %>
    </div>

    <div class="app-navbar__spacer"></div>

    <!-- Acciones -->
    <div class="app-navbar__actions dropdown">
      <button class="icon-btn" id="btnNotificaciones" data-bs-toggle="dropdown" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
          <path fill="currentColor"
            d="m20.52 15.21l-1.8-1.81V8.94a6.86 6.86 0 0 0-5.82-6.88a6.74 6.74 0 0 0-7.62 6.67v4.67l-1.8 1.81A1.64 1.64 0 0 0 4.64 18H8v.34A3.84 3.84 0 0 0 12 22a3.84 3.84 0 0 0 4-3.66V18h3.36a1.64 1.64 0 0 0 1.16-2.79M14 18.34A1.88 1.88 0 0 1 12 20a1.88 1.88 0 0 1-2-1.66V18h4Z" />
        </svg>
      </button>
      <div id="notificacionesDropdown" class="dropdown-menu dropdown-menu-end app-navbar__dropdown">
        <div class="p-3 text-muted">No tienes notificaciones</div>
      </div>

      <div class="dropdown">
        <button class="icon-avatar" id="btnPerfil" data-bs-toggle="dropdown" aria-expanded="false">
          <span class="material-icons">person</span>
        </button>
        <div class="dropdown-menu dropdown-menu-end app-navbar__dropdown">
          <div class="app-navbar__dropdown-header">
            <div class="fw-bold">Mi cuenta</div>
            <% if (session && session.user) { %>
            <div class="small text-muted"><%= session.user.nombreusuario %></div>
            <% } %>
          </div>
          <div class="dropdown-divider"></div>
          <form method="POST" action="/auth/logout" style="margin: 0;">
            <button type="submit" class="dropdown-item d-flex align-items-center gap-2 p-2 mb-2">
              <span class="material-icons" style="font-size: 18px;">logout</span>
              Cerrar sesión
            </button>
          </form>
        </div>
      </div>
    </div>

  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="/javascripts/navbar.js"></script>
</header>