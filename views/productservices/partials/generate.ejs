<style>
  .app-field.campo-invalido .app-input,
  .app-field.campo-invalido .app-select {
    border-color: #ef4444;
    box-shadow: 0 0 0 1px #ef4444;
  }
  .app-field.campo-invalido label { color: #ef4444; }

  .app-field.campo-valido .app-input,
  .app-field.campo-valido .app-select {
    border-color: #22c55e;
    box-shadow: 0 0 0 1px #22c55e;
  }
  .app-field.campo-valido label { color: #22c55e; }

  .ps-tooltip-btn {
    flex-shrink: 0;
    background: #fff;
    border: 1px solid var(--grey-400, #c4c4c4);
    border-left: none;
    border-radius: 0 8px 8px 0;
    padding: 0 10px;
    cursor: help;
    color: #1c6bff;
    font-weight: 700;
    font-size: 14px;
    min-width: 36px;
    transition: background 0.2s;
  }
  .ps-tooltip-btn:hover { background: #f0f4ff; }
</style>

<div class="container-details">

  <%# Paso 1: selección de producto %>
  <div id="tab-generate-select">
    <div class="row g-3">
      <h4>Generar Solicitud</h4>
      <p>Selecciona el producto o servicio que deseas solicitar.</p>
      <div class="col-12 col-md-5 mx-auto mb-4">
        <div class="app-field select mb-3">
          <select class="app-select" id="productoServicio" name="productoServicio" required>
            <option value="" disabled selected hidden></option>
          </select>
          <label for="productoServicio">Producto o Servicio</label>
        </div>
        <div class="d-flex gap-2 justify-content-end">
          <button type="button" class="app-button primary w-100" id="btn-generate-cancel">Cancelar</button>
          <button type="button" class="app-button primary w-100" id="btn-generate-form">Siguiente</button>
        </div>
      </div>
    </div>
  </div>

  <%# Paso 2: formulario de solicitud %>
  <div id="tab-generate-form" style="display:none;">
    <form id="formSolicitud" novalidate autocomplete="off">

      <%# Info del producto %>
      <div class="col-md-8 mx-auto text-start mb-4">
        <div class="secondary-header mb-3 p-2 rounded-3">
          <h5 class="mb-0">Información Producto / Servicio</h5>
        </div>
        <div class="mb-3 app-field">
          <input type="text" class="app-input" id="NomProd" placeholder=" " readonly>
          <label for="NomProd">Producto / Servicio</label>
        </div>
        <div class="mb-3 app-field">
          <textarea class="app-input" id="DescProd" rows="3" placeholder=" " readonly></textarea>
          <label for="DescProd"></label>
        </div>
      </div>

      <%# Adjuntos %>
      <div class="col-md-8 mx-auto text-start mb-4" id="seccion-adjuntos" style="display:none;">
        <div class="secondary-header mb-3 p-2 rounded-3">
          <h5 class="mb-0">Adjuntos</h5>
        </div>
        <div class="row mb-2 d-none d-md-flex">
          <div class="col-sm-4"></div>
          <div class="col-sm-5"></div>
          <div class="col-sm-3 text-center fw-semibold">Es obligatorio</div>
        </div>
        <div id="lista-adjuntos"></div>
      </div>

      <%# Campos dinámicos %>
      <div class="col-md-8 mx-auto text-start mb-4" id="seccion-campos" style="display:none;">
        <div class="secondary-header mb-3 p-2 rounded-3">
          <h5 class="mb-0">Información Adicional</h5>
        </div>
        <div class="row mb-2 d-none d-md-flex">
          <div class="col-sm-4"></div>
          <div class="col-sm-5"></div>
          <div class="col-sm-3 text-center fw-semibold">Es obligatorio</div>
        </div>
        <div id="lista-campos"></div>
      </div>

      <%# Observaciones %>
      <div class="col-md-8 mx-auto text-start mb-4">
        <div class="secondary-header mb-3 p-2 rounded-3">
          <h5 class="mb-0">Observaciones</h5>
        </div>
        <div class="app-field">
          <textarea class="app-input" id="ObservacionProd" name="observacion" rows="4" placeholder="Déjanos tus observaciones"></textarea>
          <label for="ObservacionProd"></label>
        </div>
      </div>

      <%# Acciones %>
      <div class="col-md-8 mx-auto d-flex gap-2 justify-content-end mb-4">
        <button type="button" class="app-button primary" id="btn-form-back">Regresar</button>
        <button type="submit" class="app-button primary" id="btn-submit-solicitud">Enviar Solicitud</button>
      </div>

    </form>
  </div>

</div>
