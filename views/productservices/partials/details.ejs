<div class="container-fluid px-0">

  <div class="secondary-header mb-3 p-2 rounded-3">
    <h5 class="mb-0">Estado de Solicitudes</h5>
  </div>
  <p class="text-muted mb-3">
    Lista de solicitudes realizadas ordenadas de la más nueva a la más antigua.
    Da clic en <strong>Ver más</strong> para ver el historial de estados.
  </p>

  <div class="table-responsive">
    <table class="table table-bordered align-middle">
      <thead class="table-light">
        <tr>
          <th class="text-center">N. Solicitud</th>
          <th class="text-center">Producto</th>
          <th class="text-center">F. Solicitud</th>
          <th class="text-center">Último estado</th>
          <th class="text-center">Ver más</th>
        </tr>
      </thead>
      <tbody id="tbody-solicitudes">
        <tr id="fila-cargando">
          <td colspan="5" class="text-center text-muted py-4">Cargando solicitudes...</td>
        </tr>
      </tbody>
    </table>
  </div>

</div>

<%# Modal seguimiento %>
<div class="modal fade" id="modalSeguimiento" tabindex="-1" aria-labelledby="tituloModalSeguimiento" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="tituloModalSeguimiento">Ver estado solicitud</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>

      <div class="modal-body">
        <div class="row mb-2">
          <label class="col-sm-4 col-form-label fw-semibold">Fecha solicitud</label>
          <div class="col-sm-8">
            <input type="text" class="form-control" id="modal-fecha" readonly>
          </div>
        </div>
        <div class="row mb-2">
          <label class="col-sm-4 col-form-label fw-semibold">N. Solicitud</label>
          <div class="col-sm-8">
            <input type="text" class="form-control" id="modal-numero" readonly>
          </div>
        </div>
        <div class="row mb-3">
          <label class="col-sm-4 col-form-label fw-semibold">Producto / Servicio</label>
          <div class="col-sm-8">
            <input type="text" class="form-control" id="modal-producto" readonly>
          </div>
        </div>

        <table class="table table-bordered">
          <thead class="table-light">
            <tr>
              <th class="text-center">Fecha estado</th>
              <th class="text-center">Estado</th>
              <th>Observaciones</th>
            </tr>
          </thead>
          <tbody id="tbody-seguimiento">
          </tbody>
        </table>
      </div>

      <div class="modal-footer">
        <button type="button" class="app-button primary" data-bs-dismiss="modal">Cerrar</button>
      </div>

    </div>
  </div>
</div>
