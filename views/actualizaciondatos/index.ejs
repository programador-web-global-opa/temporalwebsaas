<section class="container-fluid py-3 px-3">
    <header class="row mb-4">
        <div class="col-12">
            <div class="primary-header">
                <h1 class="mb-0">Actualizaci&oacute;n de datos</h1>
            </div>
        </div>
    </header>

    <% if (puedeIngresar === false) { %>
    <section class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="app-paper elevation-4 p-4 text-center">
                <h2 class="mb-3">Acceso no disponible</h2>
                <p class="mb-0"><%= mensajeAcceso || "No es posible ingresar al modulo en este momento." %></p>
            </div>
        </div>
    </section>

    <div class="modal fade app-modal" id="modalAccesoActualizacion" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 650px; max-height: 580px;">
            <div class="modal-content app-modal__content">
                <div class="app-modal__header justify-content-center border-0 pb-0">
                    <div
                        class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                        style="width: 64px; height: 64px; border: 3px solid <%= tipoMensajeAcceso === 'exito' ? '#22c55e' : '#f0ad4e' %>; color: <%= tipoMensajeAcceso === 'exito' ? '#22c55e' : '#f0ad4e' %>; font-size: 1.25rem; line-height: 1;">
                        <%= tipoMensajeAcceso === "exito" ? "OK" : "!" %>
                    </div>
                </div>
                <div class="app-modal__body text-center pt-3" style="font-size: 25px;">
                    <%= mensajeAcceso || "No es posible ingresar al modulo en este momento." %>
                </div>
                <div class="app-modal__footer justify-content-center border-0 pt-0">
                    <button type="button" class="app-button" data-bs-dismiss="modal">Aceptar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modalElement = document.getElementById("modalAccesoActualizacion");
            if (!modalElement || typeof bootstrap === "undefined") return;
            const modal = new bootstrap.Modal(modalElement);
            modal.show();
        });
    </script>
    <% } else { %>
    <section class="app-tabs">
        <a href="#" class="app-tab" id="tab-autorizaciones" data-tab="autorizaciones">Autorizaciones</a>
        <a href="#" class="app-tab" id="tab-datosPersonales" data-tab="datosPersonales">Datos Personales</a>
        <a href="#" class="app-tab" id="tab-datosLaborales" data-tab="datosLaborales">Datos Laborales</a>
        <a href="#" class="app-tab" id="tab-otrosDatos" data-tab="otrosDatos">Otros Datos</a>
        <a href="#" class="app-tab" id="tab-ingresosEgresos" data-tab="ingresosEgresos">Ingresos y Egresos</a>
        <a href="#" class="app-tab" id="tab-adjuntos" data-tab="adjuntos">Adjuntos</a>
        <a href="#" class="app-tab" id="tab-referencias" data-tab="referencias">Referencias</a>
        <a href="#" class="app-tab" id="tab-personasACargo" data-tab="personasACargo">Personas a Cargo</a>
        <a href="#" class="app-tab" id="tab-conyugue" data-tab="conyugue">Conyugue</a>
        <a href="#" class="app-tab" id="tab-familiaresPeps" data-tab="familiaresPeps">Familiares Peps</a>
        <a href="#" class="app-tab" id="tab-otrosDatosAdicionales" data-tab="otrosDatosAdicionales">Otros Datos Adicionales</a>
        <button class="app-button" id="btnFinalizar" style="width: 100px; height: 40px;">Finalizar Actualizaci&oacute;n</button>
    </section>

    <div class="progress mb-3">
        <div
            id="progressBar"
            class="progress-bar progress-bar-striped progress-bar-personalized"
            role="progressbar"
            style="width: 9.090909090909092%"
            aria-valuenow="10"
            aria-valuemin="0"
            aria-valuemax="100"></div>
    </div>

    <section>
        <div class="alert alert-warning py-2">
            La informacion marcada con <strong style="color: #f74a4a;">*</strong> es obligatoria
        </div>
    </section>

    <section class="row mb-3">
        <div class="col-12" id="tab-content"></div>
    </section>

    <script src="/javascripts/actualizacionDatos.js"></script>
    <% } %>
</section>
