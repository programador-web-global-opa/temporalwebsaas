<!-- IZQUIERDA (contenido login) -->
<div class="main-container">
  <div class="paper">
    <form id="form-step-1" class="form">
      <div id="step-1">
        <div class="content-img">
          <img
            src="https://res.cloudinary.com/dlzrekadn/image/upload/v1633634924/opa-transactional-web-admin/p4zxpnghia7hbeoioflf.png"
            class="imagen-entidad"
            alt="Imagen logo entidad"
          />
        </div>
        <h2 class="bienvenido">Bienvenido</h2>

        <div class="contenedor-global">
          <div class="contenedor-formulario">
            <div class="mui-textfield usuario" id="input-login-user">
              <span class="material-icons mui-icon">person_outline</span>
              <input
                type="text"
                id="usuario"
                placeholder="Usuario"
                autofocus
                autocomplete="off"
              />
            </div>
            <small class="error" id="error-usuario"></small>

            <div class="contenedor-boton">
              <button type="submit" class="boton-nuevo" id="btnSiguiente">
                Ingresar
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="urls-basicas-contenedor">
        <a href="/auth/recover-user" class="urls-basicas">Recordar usuario</a>
        <a href="/auth/register" class="urls-basicas">¿No tienes una cuenta?</a>
      </div>
    </form>

    <form id="form-step-2" class="form" style="display: none; max-width: 395px;">
      <div class="app-paper elevation-8">
        <img
          id="security-image"
          src="/images/usuario.png"
          class="security-image"
          alt="Imagen seguridad"
        />
        <div class="mui-card-content">
          <small class="error" id="error-check"></small>
          <label class="mui-checkbox-label checkbox">
            <input type="checkbox" name="imagen" id="confirm-image" />
            <span class="custom-checkbox"></span>
            Confirme que esta es su imagen y frase registrada
          </label>
        </div>
      </div>

      <div class="mui-textfield" style="margin-top: 16px" id="input-login-password">
        <span class="material-icons mui-icon">lock</span>
        <input
          type="password"
          id="password"
          placeholder="Password"
          autofocus
          autocomplete="off"
        />
        <span class="material-icons mui-icon-eye" id="togglePassword" style="cursor: pointer; color: #757575;">
          visibility_off
        </span>
      </div>
      <small class="error" id="error-password"></small>

      <div class="contenedor-boton" style="margin-top: 24px">
        <button
          type="button"
          class="boton-nuevo"
          onclick="goBack()"
        >
          <span
            class="material-icons"
            style="font-size: 14px; margin-right: 5px"
            >arrow_back_ios</span
          >
          Regresar
        </button>
        <button type="submit" class="boton-nuevo">
          Ingresar
        </button>
      </div>

      <div class="urls-basicas-contenedor">
        <a href="/auth/recover-password" class="urls-basicas">¿Olvidaste tu contraseña?</a>
        <a href="/auth/register" class="urls-basicas">¿No tienes una cuenta?</a>
      </div>
    </form>

    <div id="loading" class="loading">
      <div class="spinner"></div>
      <span>Cargando...</span>
    </div>

  </div>

  <div style="margin-top: 16px; display: flex; justify-content: center; align-items: center;">
    <button class="app-button-security" tabindex="0" type="button" id="btnOpenModal">
      <span
        style="font-size: 20px; margin-right: 4px; display: flex; justify-content: center; align-items: center; gap: 10px;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          aria-hidden="true"
          role="img"
          width="1em"
          height="1em"
          preserveAspectRatio="xMidYMid meet"
          viewBox="0 0 24 24"
        >
          <g id="iconifyReact0">
            <g id="iconifyReact1">
              <g id="iconifyReact2" fill="currentColor">
                <circle cx="12" cy="15" r="1"></circle>
                <path
                  d="M17 8h-1V6.11a4 4 0 1 0-8 0V8H7a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-8a3 3 0 0 0-3-3Zm-7-1.89A2.06 2.06 0 0 1 12 4a2.06 2.06 0 0 1 2 2.11V8h-4ZM12 18a3 3 0 1 1 3-3a3 3 0 0 1-3 3Z"
                ></path>
              </g>
            </g>
          </g>
        </svg>
      </span>
      Mensaje de Seguridad
    </button>
  </div>

  <p class="app-copy mt-4" style="text-align: center">
    Copyright ©
    <a class="app-copy-link" href="https://opa.com.co/"> OPA S.A.S </a>
    <%= new Date().getFullYear() %>
  </p>
  <p
    style="text-align: center; color: rgb(111, 111, 111); font-size: 14px"
  >
    Al ingresar al sitio web aceptas los términos y condiciones de uso.
  </p>
</div>

<!-- MODAL -->
<div class="modal-backdrop" id="securityModal" style="display: none;">
  <div class="modal-box">
    <p>Se abrirá una nueva ventana exclusivamente para el manejo de Servicios en Línea, en la cual deberás ingresar tu usuario y tu contraseña personal para acceder al servicio de forma segura.</p><br>
    <p>Recuerda que, por políticas de seguridad, <strong>OPA S.A.S</strong> nunca se solicitará información personal ni de tus cuentas a través de correo electrónico o mensajes de texto.</p><br>
    <p>Es recomendable cambiar tu contraseña de acceso de manera periódica para proteger tu cuenta.</p><br>
    <p>Siempre que vayas a realizar transacciones por Internet, hazlo desde tu computador personal en casa u oficina.</p><br>
    <p>Para tu seguridad, realiza siempre tus transacciones por Internet desde un computador personal en casa o en tu oficina, evitando dispositivos públicos o compartidos. Además, siempre ingresa directamente a la página oficial desde tu navegador. No accedas a través de enlaces en correos electrónicos ni en otros sitios web para evitar fraudes.</p><br>
    <div class="contenedor-boton">
      <button id="btnCerrar" class="boton-nuevo">Cerrar</button>
    </div>
  </div>
</div>

<script>
  /**
   *  Inicio de modal
  */
  const modal = document.getElementById('securityModal');
  const btnAbrir = document.getElementById('btnOpenModal');
  const btnCerrar = document.getElementById('btnCerrar');

  function abrirModal() {
    modal.classList.add('show-custom');
    modal.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function cerrarModal() {
    modal.classList.remove('show-custom');
    modal.style.display = 'none';
    document.body.style.overflow = 'auto';
  }

  btnAbrir.addEventListener('click', abrirModal);
  btnCerrar.addEventListener('click', cerrarModal);

  window.addEventListener('click', (event) => {
    if (event.target === modal) {
      cerrarModal();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal.classList.contains('show')) {
      cerrarModal();
    }
  });
  /**
   *  Fin de modal
  */


  /**
   *  Inicio Login
  */
  let step = 1;
  let temporalDocument = "";

  const form1 = document.getElementById("form-step-1");
  const form2 = document.getElementById("form-step-2");

  form1.addEventListener("submit", async (e) => {
    e.preventDefault();

    const username = document.getElementById("usuario").value;
    const error = document.getElementById("error-usuario");
    const errorinput = document.getElementById("input-login-user");

    if (!username.trim()) {
      error.textContent = "El usuario no existe o está vacio";
      errorinput.classList.add("error"); 
      return;
    }

    error.textContent = "";
    errorinput.classList.remove("error");

    activeLoading(true);
    await validateUser(username);
  });

  form2.addEventListener("submit", async (e) => {
    e.preventDefault();

    const confirmImage = document.getElementById("confirm-image").checked;
    const password = document.getElementById("password").value;
    const errorinput = document.getElementById("input-login-password");
    
    let valid = true;

    if (!password.trim()) {
      document.getElementById("error-password").textContent = "Ingrese contraseña";
      errorinput.classList.add("error");
      valid = false;
    }

    if (!confirmImage) {
      document.getElementById("error-check").textContent = "Debes confirmar la imagen";
      valid = false;
    }

    if (!valid) return;

    activeLoading(true);
    await login(password, confirmImage);
  });

  function goToStep(n) {
    step = n;

    form1.style.display = 'none';
    form2.style.display = 'none';
    loading.classList.remove("active");

    if (n === 1) {
      form1.style.display = 'block';
      return;
    }
    if (n === 2) {
      form2.style.display = 'block';
      return;
    }
  }

  function goBack() {
    goToStep(1);
  }

  function activeLoading(status = false) {
    const loading = document.getElementById("loading");
    if (status) loading.classList.add("active");
    if (!status) loading.classList.remove("active");
  }

  async function validateUser(user) {
    try {
      const response = await fetch("/auth/validateUser", {
        method: 'POST',
        headers: headers(),
        body: JSON.stringify({
          "user": user
        }),
      });

      const data = await response.json();

      if (!data?.result?.cedula) {
        document.getElementById("input-login-user").classList.add("error");
        document.getElementById("error-usuario").textContent = data?.message ?? "Usuario no invalido";
        return;
      }

      temporalDocument = data?.result?.cedula;
      document.getElementById("security-image").src = data?.result?.url; 
      goToStep(2);

    } catch (error) {
      console.log(error);
      document.getElementById("error-usuario").textContent = "Usuario no invalido";
    } finally {
      activeLoading(false);
    }
  }

  async function login(password, confirmImage) {
    try {
      const response = await fetch("/auth", {
        method: 'POST',
        headers: headers(),
        body: JSON.stringify({
          "user": temporalDocument,
          "password": password,
          "url": document.getElementById("security-image").src
        }),
      });

      const data = await response.json();

      if (!data?.result) {
        document.getElementById("input-login-password").classList.add("error");
        document.getElementById("error-password").textContent = data?.message ?? "Usuario no invalido";
        return;
      }

      window.location.href = "/ahorro/devolucion";
    } catch (error) {
      console.log(error);
      document.getElementById("input-login-password").classList.add("error");
      document.getElementById("error-password").textContent = "Usuario no invalido";
    } finally {
      activeLoading(false);
    }
  }

  /**
   *  Fin Login
  */

  /**
   *  Cambio del icono password Login
  */

  function togglePassword() {
    const inputPassword = document.getElementById("password");
    inputPassword.type = inputPassword.type === "password" ? "text" : "password";
  }

  const inputPassword = document.getElementById('password');
  const btnToggle = document.getElementById('togglePassword');

  btnToggle.addEventListener('click', function () {
      const isPassword = inputPassword.type === 'password';
      inputPassword.type = isPassword ? 'text' : 'password';
      
      this.textContent = isPassword ? 'visibility' : 'visibility_off';
      
      inputPassword.focus();
  });

  inputPassword.addEventListener('blur', () => {
      setTimeout(() => {
          inputPassword.focus();
      }, 10);
  });

  window.onload = () => inputPassword.focus();
  /**
   *  Fin Cambio del icono password Login
  */

  const headers = (headersOptions = {}) => {
    const myHeaders = new Headers();
    myHeaders.append("Content-Type", "application/json");

    return myHeaders;
  }
</script>
