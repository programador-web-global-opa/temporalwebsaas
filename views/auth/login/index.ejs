<!-- IZQUIERDA (contenido login) -->
<div class="main-container">
  <div class="paper">
    <form id="form-step-1" class="form d-none" style="max-width: 395px;">
      <div id="step-1">
        <div class="content-img">
          <img
            src="https://res.cloudinary.com/dlzrekadn/image/upload/v1633634924/opa-transactional-web-admin/p4zxpnghia7hbeoioflf.png"
            class="imagen-entidad"
            alt="Imagen logo entidad"
          />
        </div>
        <h2 class="bienvenido">Bienvenido</h2>

        <div class="contenedor-global">
          <div class="contenedor-formulario">
            <div class="mui-textfield usuario" id="input-login-user">
              <span class="material-icons mui-icon">person_outline</span>
              <input
                type="text"
                id="usuario"
                placeholder="Usuario"
                autofocus
                autocomplete="off"
              />
            </div>
            <small class="error" id="error-usuario"></small>

            <div class="contenedor-boton">
              <button type="submit" class="boton-nuevo" id="btnSiguiente">
                Ingresar
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="urls-basicas-contenedor">
        <a href="/auth/recover-user" class="urls-basicas">Recordar usuario</a>
        <a href="/auth/register" class="urls-basicas">¿No tienes una cuenta?</a>
      </div>
    </form>

    <form id="form-step-2" class="form d-none" style="max-width: 395px;">
      <div class="app-paper elevation-8">
        <img
          id="security-image"
          src="/images/usuario.png"
          class="security-image"
          alt="Imagen seguridad"
        />
        <div class="mui-card-content">
          <small class="error" id="error-check"></small>
          <label class="mui-checkbox-label checkbox">
            <input type="checkbox" name="imagen" id="confirm-image" />
            <span class="custom-checkbox"></span>
            Confirme que esta es su imagen y frase registrada
          </label>
        </div>
      </div>

      <div class="mui-textfield" style="margin-top: 16px" id="input-login-password">
        <span class="material-icons mui-icon">lock</span>
        <input
          type="password"
          id="password"
          placeholder="Password"
          autocomplete="off"
        />
        <span class="material-icons mui-icon-eye" id="togglePassword" style="cursor: pointer; color: #757575;">
          visibility_off
        </span>
      </div>
      <small class="error" id="error-password" style="width: 100%;"></small>

      <div class="mui-textfield d-none" id="input-codigo-user">
        <input type="hidden" data-code="N" />
        <span class="material-icons mui-icon">password</span>
        <input
          type="text"
          id="codigo-user"
          placeholder="Ingrese Código"
          autocomplete="off"
        />
      </div>
      <small class="error" id="error-codigo-user" style="width: 100%;"></small>

      <div class="contenedor-boton" style="margin-top: 24px">
        <button
          type="button"
          class="boton-nuevo"
          onclick="goBack()"
        >
          <span
            class="material-icons"
            style="font-size: 14px; margin-right: 5px"
            >arrow_back_ios</span
          >
          Regresar
        </button>
        <button type="submit" class="boton-nuevo">
          Ingresar
        </button>
      </div>

      <div class="urls-basicas-contenedor">
        <a href="/auth/recover-password" class="urls-basicas">¿Olvidaste tu contraseña?</a>
        <a href="/auth/register" class="urls-basicas">¿No tienes una cuenta?</a>
      </div>
    </form>

    <div id="loading" class="loading active">
      <div class="spinner"></div>
      <span>Cargando...</span>
    </div>

  </div>

  <div style="margin-top: 16px; display: flex; justify-content: center; align-items: center;">
    <button class="app-button-security" tabindex="0" type="button" id="btnOpenModal">
      <span
        style="font-size: 20px; margin-right: 4px; display: flex; justify-content: center; align-items: center; gap: 10px;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          xmlns:xlink="http://www.w3.org/1999/xlink"
          aria-hidden="true"
          role="img"
          width="1em"
          height="1em"
          preserveAspectRatio="xMidYMid meet"
          viewBox="0 0 24 24"
        >
          <g id="iconifyReact0">
            <g id="iconifyReact1">
              <g id="iconifyReact2" fill="currentColor">
                <circle cx="12" cy="15" r="1"></circle>
                <path
                  d="M17 8h-1V6.11a4 4 0 1 0-8 0V8H7a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-8a3 3 0 0 0-3-3Zm-7-1.89A2.06 2.06 0 0 1 12 4a2.06 2.06 0 0 1 2 2.11V8h-4ZM12 18a3 3 0 1 1 3-3a3 3 0 0 1-3 3Z"
                ></path>
              </g>
            </g>
          </g>
        </svg>
      </span>
      Mensaje de Seguridad
    </button>
  </div>

  <p class="app-copy mt-4" style="text-align: center">
    Copyright ©
    <a class="app-copy-link" href="https://opa.com.co/"> OPA S.A.S </a>
    <%= new Date().getFullYear() %>
  </p>
  <p
    style="text-align: center; color: rgb(111, 111, 111); font-size: 14px"
  >
    Al ingresar al sitio web aceptas los términos y condiciones de uso.
  </p>
</div>

<!-- MODAL -->
<div class="modal-backdrop" id="securityModal" style="display: none;">
  <div class="modal-box">
    <p>Se abrirá una nueva ventana exclusivamente para el manejo de Servicios en Línea, en la cual deberás ingresar tu usuario y tu contraseña personal para acceder al servicio de forma segura.</p><br>
    <p>Recuerda que, por políticas de seguridad, <strong>OPA S.A.S</strong> nunca se solicitará información personal ni de tus cuentas a través de correo electrónico o mensajes de texto.</p><br>
    <p>Es recomendable cambiar tu contraseña de acceso de manera periódica para proteger tu cuenta.</p><br>
    <p>Siempre que vayas a realizar transacciones por Internet, hazlo desde tu computador personal en casa u oficina.</p><br>
    <p>Para tu seguridad, realiza siempre tus transacciones por Internet desde un computador personal en casa o en tu oficina, evitando dispositivos públicos o compartidos. Además, siempre ingresa directamente a la página oficial desde tu navegador. No accedas a través de enlaces en correos electrónicos ni en otros sitios web para evitar fraudes.</p><br>
    <div class="contenedor-boton">
      <button id="btnCerrar" class="boton-nuevo">Cerrar</button>
    </div>
  </div>
</div>

<div class="modal fade app-modal" id="modalerror" style="z-index: 2000;" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content app-modal__content">
      <div class="app-modal__body">
        <div>
          <div class="py-2 px-3" style="text-align: center;" id="body-error"></div>
          <div class="contenedor-boton">
            <button type="button" class="boton-nuevo" id="btn-modal-register">
              Ok
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('securityModal');
  const btnAbrir = document.getElementById('btnOpenModal');
  const btnCerrar = document.getElementById('btnCerrar');
  const btnModalBo = document.getElementById('btn-modal-register');
  
  let step = 1;
  let temporalDocument = "";

  const form1 = document.getElementById("form-step-1");
  const form2 = document.getElementById("form-step-2");
  const inputPassword = document.getElementById('password');
  const btnToggle = document.getElementById('togglePassword');

  window.onload = () => {
    activeLoading(false);
    form1.classList.remove("d-none");
    document.getElementById("usuario").focus();
  };

  window.addEventListener('click', (event) => {
    if (event.target === modal) {
      cerrarModal();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal.classList.contains('show-custom')) {
      cerrarModal();
    }
  });

  form1.addEventListener("submit", async (e) => {
    e.preventDefault();

    const username = document.getElementById("usuario").value;
    const error = document.getElementById("error-usuario");
    const errorinput = document.getElementById("input-login-user");

    if (!username.trim()) {
      error.textContent = "El usuario no existe o está vacio";
      errorinput.classList.add("error"); 
      return;
    }

    error.textContent = "";
    errorinput.classList.remove("error");
    form1.classList.add("d-none");
    activeLoading(true);
    await validateUser(username);
  });

  form2.addEventListener("submit", async (e) => {
    e.preventDefault();

    const confirmImage = document.getElementById("confirm-image").checked;
    const password = document.getElementById("password").value;
    const codigoUser = document.getElementById("codigo-user").value;
    const inputCodigoUser = document.getElementById("input-codigo-user");
    const errorinput = document.getElementById("input-login-password");
    const errorPassword = document.getElementById("error-password");
    const codigoOtp = document.getElementById("error-codigo-user");
    const inputCode = document.querySelector('input[data-code]');
    const errorCheck = document.getElementById("error-check");
    
    let valid = true;

    if (!password.trim()) {
      errorPassword.textContent = "Ingrese la contraseña";
      errorPassword.classList.add("error");
      errorinput.classList.add("error");
      valid = false;
    }

    if (inputCode.dataset.code === "S" && !codigoUser.trim()) {
      codigoOtp.textContent = "Ingrese el código de seguridad";
      codigoOtp.classList.add("error");
      inputCodigoUser.classList.add("error");
      valid = false;
    }

    if (!confirmImage) {
      errorCheck.textContent = "Debes confirmar la imagen";
      errorCheck.classList.add("error");
      valid = false;
    }

    if (!valid) return;

    form2.classList.add("d-none");
    activeLoading(true);
    await login(password, confirmImage, codigoUser);
  });

  btnToggle.addEventListener('click', function () {
      const isPassword = inputPassword.type === 'password';
      inputPassword.type = isPassword ? 'text' : 'password';
      
      this.textContent = isPassword ? 'visibility' : 'visibility_off';
      
      inputPassword.focus();
  });

  btnAbrir.addEventListener('click', abrirModal);

  btnCerrar.addEventListener('click', cerrarModal);

  btnModalBo.addEventListener('click', () => closeModal("modalerror"));

  function goToStep(n) {
    step = n;

    form1.classList.add("d-none");
    form2.classList.add("d-none");
    activeLoading(false);

    if (n === 1) {
      form1.classList.remove("d-none");
      document.getElementById("usuario").value = "";
      document.getElementById("password").value = "";
      document.getElementById("codigo-user").value = "";
      document.getElementById("input-codigo-user").classList.remove("error");
      document.getElementById("input-codigo-user").classList.add("d-none");
      document.getElementById("input-login-password").classList.remove("error");
      document.getElementById("error-password").classList.remove("error");
      document.getElementById("error-password").textContent = "";
      document.getElementById("error-check").textContent = "";
      document.getElementById("confirm-image").checked = false;
      document.querySelector('input[data-code]').dataset.code = "N";
      document.getElementById("error-codigo-user").textContent = "";
      document.getElementById("error-codigo-user").classList.remove("error");
      return;
    }
    if (n === 2) {
      form2.classList.remove("d-none");
      return;
    }
  }

  function goBack() {
    goToStep(1);
  }

  function activeLoading(status = false) {
    const loading = document.getElementById("loading");
    if (status) loading.classList.add("active");
    if (!status) loading.classList.remove("active");
  }

  function headers(headersOptions = {}) {
    const myHeaders = new Headers();
    myHeaders.append("Content-Type", "application/json");
    Object.entries(headersOptions).forEach(([key, value]) => {
      myHeaders.append(key, value);
    });
    return myHeaders;
  }

  function abrirModal() {
    modal.classList.add('show-custom');
    modal.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function cerrarModal() {
    modal.classList.remove('show-custom');
    modal.style.display = 'none';
    document.body.style.overflow = 'auto';
  }

  function openModal(modalId, isStatic = false) {
    const modalElement = document.getElementById(modalId);

    if (!modalElement) {
      console.error(`No existe un modal con id: ${modalId}`);
      return;
    }

    let modal = bootstrap.Modal.getInstance(modalElement);

    if (!modal) {
      modal = new bootstrap.Modal(modalElement, {
        backdrop: isStatic ? 'static' : true,
        keyboard: !isStatic // si es static, desactiva ESC
      });
    }

    modal.show();
  }

  function closeModal(modalId) {
    const modalElement = document.getElementById(modalId);

    if (!modalElement) return;

    const modal = bootstrap.Modal.getInstance(modalElement);
    modal?.hide();
  }

  async function validateUser(user) {
    const errorUser = document.getElementById("error-usuario");
    try {
      const inputCode = document.querySelector('input[data-code]');
      const errorCode = document.getElementById("error-codigo-user");
      const inputCodeUser = document.getElementById("input-codigo-user");
      const inputUser = document.getElementById("input-login-user");
      const securityImage = document.getElementById("security-image");

      const response = await fetch("/auth/validateUser", {
        method: 'POST',
        headers: headers(),
        body: JSON.stringify({
          "user": user
        }),
      });

      const data = await response.json();

      if (!data?.result?.cedula) {
        form1.classList.remove("d-none");
        inputUser.classList.add("error");
        errorUser.textContent = data?.message ?? "Usuario no válido";
        return;
      }

      if (data?.codigo === "819") {
        window.location.href = "/auth/recover-user";
        return;
      }

      if (data?.codigo === "853") {
        inputCode.dataset.code = "S";
        inputCodeUser.classList.remove("d-none");
        errorCode.textContent = "Ingrese el código de seguridad enviado a su correo";
        errorCode.classList.remove("error");
        temporalDocument = data?.result?.cedula ?? user;
        securityImage.src = data?.result?.url ?? "/images/usuario.png";
        sessionStorage.setItem("opa:movil:cedula:temp", data?.result?.cedula);
        return goToStep(2);
      }
      
      temporalDocument = data?.result?.cedula ?? user;
      securityImage.src = data?.result?.url ?? "/images/usuario.png";
      sessionStorage.setItem("opa:movil:cedula:temp", data?.result?.cedula);
      goToStep(2);

    } catch (error) {
      errorUser.textContent = "Usuario no válido";
    } finally {
      activeLoading(false);
    }
  }

  async function login(password, confirmImage, codigoUser = "") {
    try {
      const response = await fetch("/auth", {
        method: 'POST',
        headers: headers(),
        body: JSON.stringify({
          "user": temporalDocument,
          "password": password,
          "codigo": codigoUser,
          "url": document.getElementById("security-image").src,
        }),
      });

      const data = await response.json();

      if (data?.codigo === "820") {
        activeLoading(false);
        form2.classList.remove("d-none");
        document.getElementById("confirm-image").checked = false;
        document.getElementById("password").value = "";
        document.getElementById("error-password").classList.add("error");
        document.getElementById("error-password").textContent = data?.message ?? "Usuario no válido";
        document.getElementById("input-login-password").classList.add("error");
        return;
      }

      if (data?.codigo === "819") {
        activeLoading(false);
        form2.classList.remove("d-none");
        document.getElementById("confirm-image").checked = false;
        document.getElementById("password").value = "";
        document.getElementById("error-password").textContent = data?.message ?? "Usuario no válido";
        document.getElementById("input-login-password").classList.add("error");
        setTimeout(() => window.location.href = "/auth/recover-password", 3000);
        return;
      }

      if (data?.codigo === "848" || data?.codigo === "854") {
        activeLoading(false);
        form2.classList.remove("d-none");
        document.getElementById("confirm-image").checked = false;
        document.getElementById("password").value = "";
        document.getElementById("error-password").innerText = "";
        document.getElementById("body-error").innerText = data?.message ?? "Usuario no válido";
        document.getElementById("input-login-password").classList.remove("error");
        document.getElementById("error-check").innerText = "";
        openModal("modalerror");
        return;
      }

      if (!data?.result) {
        activeLoading(false);
        form2.classList.remove("d-none");
        document.getElementById("confirm-image").checked = false;
        document.getElementById("input-login-password").classList.add("error");
        document.getElementById("error-password").textContent = data?.message ?? "Usuario no válido";
        return;
      }

      window.location.href = "/ahorro/crear";
    } catch (error) {
      activeLoading(false);
      form2.classList.remove("d-none");
      document.getElementById("input-login-password").classList.add("error");
      document.getElementById("error-password").textContent = "Usuario no válido";
    }
  }
</script>
