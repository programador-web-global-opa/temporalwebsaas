<style>
  #contenedor-step-1,
  #contenedor-step-2,
  #contenedor-step-3 {
    flex-direction: column !important;
    width: 100%;
    align-items: stretch;
  }
  #contenedor-step-1 .contenedor-boton,
  #contenedor-step-2 .contenedor-boton,
  #contenedor-step-3 .contenedor-boton {
    justify-content: center;
  }
</style>

<!-- IZQUIERDA (contenido login) -->
<div class="main-container">
  <div class="paper">
    <form
      id="recover-password-form"
      class="form"
      style="width: 100%; max-width: 395px"
    >
      <div id="step-1" style="width: 100%">
        <h2 class="bienvenido">Recordar Password</h2>

        <!-- CONTENEDOR CODIGO OTP -->
        <div class="contenedor-global d-none" id="contenedor-step-1">

          <div class="contenedor-formulario">

            <p id="info-step-1" class="text-justify my-3"></p>

            <div class="mui-textfield" id="code-recover-group">
              <span class="material-icons mui-icon">password</span>
              <input
                type="text"
                id="code-recover"
                placeholder="Ingrese el codigo"
                required
                autocomplete="off"
              />
            </div>
            <small class="error" id="error-code-recover"></small>
          </div>

          <div class="contenedor-boton" id="btn-container">
            <button type="button" class="boton-nuevo w-100" id="btnRecoverStep1">
              Enviar
            </button>
          </div>
        </div>

        <!-- CONTENEDOR INPUT PASSWORD NEW Y CONFIRMAR PASSWORD NEW -->
        <div class="contenedor-global d-none" id="contenedor-step-2">
          <div class="contenedor-formulario">
            
            <div
              class="mui-textfield"
              id="recover-password-group"
            >
              <span class="material-icons mui-icon">lock</span>
              <input
                type="password"
                id="recover-password"
                placeholder="Password"
                autocomplete="off"
              />
              <span
                class="material-icons mui-icon-eye"
                id="togglePassword"
                style="cursor: pointer; color: #757575"
              >
                visibility_off
              </span>
            </div>
            <small class="error" id="error-recover-password"></small>

            <div
              class="mui-textfield"
              id="recover-password-confirm-group"
            >
              <span class="material-icons mui-icon">lock</span>
              <input
                type="password"
                id="recover-password-confirm"
                placeholder="Confirmar Password"
                required
                autocomplete="off"
              />
              <span
                class="material-icons mui-icon-eye"
                id="togglePassword"
                style="cursor: pointer; color: #757575"
              >
                visibility_off
              </span>
            </div>
            <small class="error" id="error-recover-password-confirm"></small>
          </div>
          <div class="contenedor-boton" id="btn-container">
            <button type="button" class="boton-nuevo w-100" id="btnRecoverStep2">
              Enviar
            </button>
          </div>
        </div>

        <!-- CONTENER DE INPUTS DE PREGUNTAS SI LAS TIENEN ACTIVAS -->
        <div class="contenedor-global d-none" id="contenedor-step-3">
          <div class="contenedor-formulario">

            <label for="questions-one" id="label-question-one">Pregunta 1</label>
            <div class="mui-textfield" id="questions-one-group">
              <input
                type="text"
                id="questions-one"
                placeholder="Respuesta 1"
                required
                autocomplete="off"
              />
            </div>
            <small class="error" id="error-questions-one"></small>

            <label for="questions-two" id="label-question-two">Pregunta 2</label>
            <div class="mui-textfield" id="questions-two-group">
              <input
                type="text"
                id="questions-two"
                placeholder="Respuesta 2"
                required
                autocomplete="off"
              />
            </div>
            <small class="error" id="error-questions-two"></small>

            <label for="questions-three" id="label-question-three">Pregunta 3</label>
            <div class="mui-textfield" id="questions-three-group">
              <input
                type="text"
                id="questions-three"
                placeholder="Respuesta 3"
                required
                autocomplete="off"
              />
            </div>
            <small class="error" id="error-questions-three"></small>

          </div>

          <div class="contenedor-boton" id="btn-container-step-3">
            <button type="button" class="boton-nuevo w-100" id="btnRecoverStep3">
              Enviar
            </button>
          </div>
        </div>

        <div id="loading" class="loading active">
          <div class="spinner"></div>
          <span>Cargando...</span>
        </div>
      </div>

      <div class="urls-basicas-contenedor">
        <a href="/auth/login" class="urls-basicas">¿Ya tienes una cuenta?</a>
      </div>
    </form>
  </div>

  <p class="app-copy mt-4" style="text-align: center">
    Copyright ©
    <a class="app-copy-link" href="https://opa.com.co/"> OPA S.A.S </a>
    <%= new Date().getFullYear() %>
  </p>
</div>

<!-- Modal mensajes de errores -->
<div
  class="modal fade app-modal"
  id="modalrecover"
  style="z-index: 2000"
  tabindex="-1"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content app-modal__content">
      <div class="app-modal__body">
        <div>
          <div
            class="py-2 px-3"
            style="text-align: center"
            id="body-recover"
          ></div>
          <div class="contenedor-boton">
            <button type="button" class="boton-nuevo" id="btn-modal-recover">
              Ok
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const loading = document.getElementById("loading");
  const inputGroupCode = document.getElementById("code-recover-group");
  const form = document.getElementById("recover-password-form");

  let pregunta1Id = "";
  let pregunta2Id = "";
  let pregunta3Id = "";

  const formStep1 = document.getElementById("contenedor-step-1");
  const formStep2 = document.getElementById("contenedor-step-2");
  const formStep3 = document.getElementById("contenedor-step-3");

  const textStep1 = document.getElementById("info-step-1");

  const formBtn1 = document.getElementById("btnRecoverStep1");
  const formBtn2 = document.getElementById("btnRecoverStep2");
  const formBtn3 = document.getElementById("btnRecoverStep3");

  const bodyModalMessage = document.getElementById("body-recover");
  const btnModal = document.getElementById("btn-modal-recover");
  const togglePassword = document.querySelectorAll("#togglePassword");

  togglePassword.forEach((toggle) => {
    toggle.addEventListener("click", function () {
      const passwordField = this.previousElementSibling;
      const type =
        passwordField.getAttribute("type") === "password" ? "text" : "password";
      passwordField.setAttribute("type", type);
      this.textContent = type === "password" ? "visibility_off" : "visibility";
    });
  });

  window.addEventListener("DOMContentLoaded", init);

  formBtn1.addEventListener("click", async (e) => await sendRecoverPasswordCode(e));

  formBtn2.addEventListener("click", async (e) => await validateSendNewPassword(e));

  formBtn3.addEventListener("click", async (e) => await sendQuestionsPassword(e));

  btnModal.addEventListener("click", () => closeModal("modalrecover"));

  function step(n = 1) {
    form.classList.remove("d-none");
    switch (n) {
      case 1:
        formStep1.classList.remove("d-none");
        formStep2.classList.add("d-none");
        formStep3.classList.add("d-none");
        break;
      case 2:
        formStep1.classList.add("d-none");
        formStep2.classList.remove("d-none");
        formStep3.classList.add("d-none");
        break;
      case 3:
        formStep1.classList.add("d-none");
        formStep2.classList.add("d-none");
        formStep3.classList.remove("d-none");
        break;
      default:
        formStep1.classList.remove("d-none");
        formStep2.classList.add("d-none");
        formStep3.classList.add("d-none");
        break;
    }
  }

  function validateInputs(validator = 1) {
    if (validator == 1) return validateInputCode();
    if (validator == 2) return validateInputsPassword();
    if (validator == 3) return validateInputsQuestions();
  }

  function openModal(modalId, isStatic = false) {
    const modalElement = document.getElementById(modalId);

    if (!modalElement) {
      console.error(`No existe un modal con id: ${modalId}`);
      return;
    }

    let modal = bootstrap.Modal.getInstance(modalElement);

    if (!modal) {
      modal = new bootstrap.Modal(modalElement, {
        backdrop: isStatic ? "static" : true,
        keyboard: !isStatic, // si es static, desactiva ESC
      });
    }

    modal.show();
  }

  function closeModal(modalId) {
    const modalElement = document.getElementById(modalId);

    if (!modalElement) return;

    const modal = bootstrap.Modal.getInstance(modalElement);
    modal?.hide();
  }

  function headers(headersOptions = {}) {
    const myHeaders = new Headers();
    myHeaders.append("Content-Type", "application/json");
    Object.entries(headersOptions).forEach(([key, value]) => {
      myHeaders.append(key, value);
    });
    return myHeaders;
  }

  function validateInputCode() {
      const codeInput = document.getElementById("code-recover");
      const inputGroupCode = document.getElementById("code-recover-group");
      const errorCodeGroup = document.getElementById("error-code-recover");

      if (codeInput.value === "") {
        inputGroupCode.classList.add("error");
        errorCodeGroup.innerText = "Código es requerido";
        return false;
      } else {
        inputGroupCode.classList.remove("error");
        errorCodeGroup.innerText = "";
      }
      return true;
  }

  function validateInputsPassword() {
    const inputPasswordGroup = document.getElementById("recover-password-group");
    const inputPasswordGroupConfirm = document.getElementById("recover-password-confirm-group");
    const inputPassword = document.getElementById("recover-password");
    const inputPasswordConfirm = document.getElementById("recover-password-confirm");
    const errorPassword= document.getElementById("error-recover-password");
    const errorPasswordConfirm = document.getElementById("error-recover-password-confirm");

    if (inputPassword.value === "") {
      inputPasswordGroup.classList.add("error");
      errorPassword.innerText = "La contraseña no puede estar vacia";
    }
    
    if (inputPasswordConfirm.value === "") {
      inputPasswordGroupConfirm.classList.add("error");
      errorPasswordConfirm.innerText = "La confirmación de la contraseña no puede estar vacia";
    }
    
    if (!inputPassword.value.trim() || !inputPasswordConfirm.value.trim()) {
      bodyModalMessage.innerText = "Los campos no pueden estar vacios, por favor verifique";
      openModal("modalrecover");
      return false;
    } else {
      inputPasswordGroup.classList.remove("error");
      errorPassword.innerText = "";
      inputPasswordGroupConfirm.classList.remove("error");
      errorPasswordConfirm.innerText = "";
    }

    if (
      inputPassword.value.length < 4 || inputPassword.value.length > 20
      || !inputPassword.value.match(/[0-9]/g)
      || !inputPassword.value.match(/[A-Z]/g)
      || !inputPassword.value.match(/[a-z]/g)
      || !inputPassword.value.match(/[@#$%*]/)
    ) {
      inputPasswordGroup.classList.add("error");
      errorPassword.innerText = "La contraseña debe tener entre 4 y 20 caracteres, al menos un número, una letra mayúscula, una letra minúscula y un símbolo";
      inputPasswordGroupConfirm.classList.add("error");
      errorPasswordConfirm.innerText = "La contraseña debe tener entre 4 y 20 caracteres, al menos un número, una letra mayúscula, una letra minúscula y un símbolo";
      return false;
    } else {
      inputPasswordGroup.classList.remove("error");
      errorPassword.innerText = "";
      inputPasswordGroupConfirm.classList.remove("error");
      errorPasswordConfirm.innerText = "";
    }

    if (inputPassword.value !== inputPasswordConfirm.value) {
      inputPasswordGroup.classList.add("error");
      errorPassword.innerText = "Las contraseñas no coinciden...Verifique por favor";
      inputPasswordGroupConfirm.classList.add("error");
      errorPasswordConfirm.innerText = "Las contraseñas no coinciden...Verifique por favor";
      return false;
    } else {
      inputPasswordGroup.classList.remove("error");
      errorPassword.innerText = "";
      inputPasswordGroupConfirm.classList.remove("error");
      errorPasswordConfirm.innerText = "";
    }

    return true;
  }

  function validateInputsQuestions() {
    const questionOneGroup = document.getElementById("questions-one-group");
    const questionTwoGroup = document.getElementById("questions-two-group");
    const questionThreeGroup = document.getElementById("questions-three-group");
    const inputQuestionOne = document.getElementById("questions-one");
    const inputQuestionTwo = document.getElementById("questions-two");
    const inputQuestionThree = document.getElementById("questions-three");
    const errorQuestionOne = document.getElementById("error-questions-one");
    const errorQuestionTwo = document.getElementById("error-questions-two");
    const errorQuestionThree = document.getElementById("error-questions-three");

    if (inputQuestionOne.value == "") {
      questionOneGroup.classList.add("error");
      errorQuestionOne.innerText = "La pregunta es obligatoria";
    }
    if (inputQuestionTwo.value == "") {
      questionTwoGroup.classList.add("error");
      errorQuestionTwo.innerText = "La pregunta es obligatoria";
    }
    if (inputQuestionThree.value == "") {
      questionThreeGroup.classList.add("error");
      errorQuestionThree.innerText = "La pregunta es obligatoria";
    }

    if (
      !inputQuestionOne.value.trim() ||
      !inputQuestionTwo.value.trim() ||
      !inputQuestionThree.value.trim()
    ) {
      return false;
    } else {
      questionOneGroup.classList.remove("error");
      errorQuestionOne.innerText = "";
      questionTwoGroup.classList.remove("error");
      errorQuestionTwo.innerText = "";
      questionThreeGroup.classList.remove("error");
      errorQuestionThree.innerText = "";
    }

    return true;
  }

  async function init() {
    await getRecoverPasswordCode();
  }

  async function getRecoverPasswordCode() {
    try {
      const params = {
        tipo: "Genera",
        Operador: sessionStorage.getItem("opa:movil:cedula:temp") || "",
        codigo: "",
        esoperador: "N",
      };

      const response = await fetchData("/auth/recover-password", params);

      if (response?.status == 400 || response?.status == 401) {
        openModal("modalrecover");
        bodyModalMessage.innerText = response?.message;
        loading.classList.remove("active");
        formStep1.classList.remove("d-none");
        return;
      }

      if (response?.codigo === "128") {
        textStep1.innerHTML = `<strong>${response?.message}</strong>`;
        formStep1.classList.remove("d-none");
        loading.classList.remove("active");
        return;
      }

      if (
        response?.status == 200 &&
        response?.codigo == "131" &&
        response?.result?.preguntasclaveprincipal == "N"
      ) {
        bodyModalMessage.innerText = response?.message;
        loading.classList.remove("active");
        step(2);
        openModal("modalrecover");
        return;
      }

      if (
        response?.status == 200 &&
        response?.codigo == "131" &&
        response?.result?.preguntasclaveprincipal == "S"
      ) {
        bodyModalMessage.innerText = response?.message;
        loading.classList.remove("active");
        step(3);
        await getQuestionsPassword()
        return;
      }

      openModal("modalrecover");
      bodyModalMessage.innerText = response?.message || "Ha ocurrido un error inesperado";
      loading.classList.remove("active");
    } catch (error) {
      openModal("modalrecover");
      bodyModalMessage.innerText = "Ha ocurrido un error inesperado, vuelva a intentarlo";
      loading.classList.remove("active");
      formStep1.classList.remove("d-none");
    }
  }

  async function sendRecoverPasswordCode(e) {
    e.preventDefault();
    const codeInput = document.getElementById("code-recover");

    if (!validateInputs(1)) return;

    form.classList.add("d-none");
    loading.classList.add("active");

    const params = {
      Operador: sessionStorage.getItem("opa:movil:cedula:temp") || "",
      tipo: "Valida",
      codigo: codeInput.value,
      esoperador: "N",
    };

    const response = await fetchData("/auth/recover-password", params);

    if (response?.error) {
      bodyModalMessage.innerText = response?.message;
      loading.classList.remove("active");
      form.classList.remove("d-none");
      openModal("modalrecover");
      return;
    }

    if (response?.status == 200 && response?.codigo == "132") {
      bodyModalMessage.innerText = response?.message;
      loading.classList.remove("active");
      step(2);
      openModal("modalrecover");
      return;
    }

    if (
      response?.status == 200 &&
      response?.codigo == "131" &&
      response?.result?.preguntasclaveprincipal == "N"
    ) {
      bodyModalMessage.innerText = response?.message;
      loading.classList.remove("active");
      step(2);
      openModal("modalrecover");
      return;
    }

    if (
      response?.status == 200 &&
      response?.codigo == "131" &&
      response?.result?.preguntasclaveprincipal == "S"
    ) {
      bodyModalMessage.innerText = response?.message;
      loading.classList.remove("active");
      step(3);
      await getQuestionsPassword();
      return;
    }

    openModal("modalrecover");
    bodyModalMessage.innerText = response?.message;
    loading.classList.remove("active");
    form.classList.remove("d-none");
  }

  async function validateSendNewPassword(e) {
    e.preventDefault();
    try {
      if (!validateInputs(2)) return;

      const cedula = sessionStorage.getItem("opa:movil:cedula:temp") || "";
      const password = document.getElementById("recover-password").value;

      formStep2.classList.add("d-none");
      loading.classList.add("active");

      const response = await fetchData("/auth/recover-password/change", { usuario: cedula, clave: password });

      localStorage.clear();
      sessionStorage.clear();

      bodyModalMessage.innerText = response?.message ?? "";
      loading.classList.remove("active");

      if (response?.codigo === "133") {
        openModal("modalrecover");
      }

      loading.querySelector("span").textContent = "Te redirigiremos al inicio de sesión...";
      loading.classList.add("active");
      setTimeout(() => { window.location.href = "/auth/login"; }, 1500);
    } catch (error) {
      bodyModalMessage.innerText = "Ha ocurrido un error al realizar la acción, por favor vuelva e intente más tarde.";
      loading.classList.remove("active");
      formStep2.classList.remove("d-none");
      openModal("modalrecover");
    }
  }

  async function getQuestionsPassword() {
    try {
      const cedula = sessionStorage.getItem("opa:movil:cedula:temp") || "";
      const params = {
        operador: cedula,
        esoperador: 'N',
        xml: "<root><parameters><Tipo>CONPRE</Tipo></parameters></root>"
      };
      const response = await fetchData("/auth/recover-password/questions", params);

      const questions = response?.result?.questions;

      if (!questions?.length) {
        bodyModalMessage.innerText = "Usted no ha registrado preguntas de seguridad, comuníquese con su administrador";
        openModal("modalrecover");
        return;
      }

      document.getElementById("label-question-one").textContent = questions[0]?.pregunta ?? "Pregunta 1";
      document.getElementById("label-question-two").textContent = questions[1]?.pregunta ?? "Pregunta 2";
      document.getElementById("label-question-three").textContent = questions[2]?.pregunta ?? "Pregunta 3";
      pregunta1Id = questions[0]?.idregistro ?? "";
      pregunta2Id = questions[1]?.idregistro ?? "";
      pregunta3Id = questions[2]?.idregistro ?? "";
    } catch (error) {
      bodyModalMessage.innerText = "Ha ocurrido un error al cargar las preguntas de seguridad";
      openModal("modalrecover");
    }
  }

  async function sendQuestionsPassword(e) {
    e.preventDefault();
    try {
      if (!validateInputs(3)) return;

      const cedula = sessionStorage.getItem("opa:movil:cedula:temp") || "";
      const respuesta1 = document.getElementById("questions-one").value;
      const respuesta2 = document.getElementById("questions-two").value;
      const respuesta3 = document.getElementById("questions-three").value;

      formStep3.classList.add("d-none");
      loading.classList.add("active");

      const params = {
        operador: cedula,
        esoperador: 'N',
        xml: `<root><parameters><Tipo>CONRES</Tipo><pregunta>${pregunta1Id}</pregunta><respuesta>${respuesta1}</respuesta><pregunta1>${pregunta2Id}</pregunta1><respuesta1>${respuesta2}</respuesta1><pregunta2>${pregunta3Id}</pregunta2><respuesta2>${respuesta3}</respuesta2></parameters></root>`
      };

      const response = await fetchData("/auth/recover-password/questions", params);

      bodyModalMessage.innerText = response?.message ?? "";
      loading.classList.remove("active");
      openModal("modalrecover");

      if (Number(response?.codigo) === 125) {
        step(2);
        return;
      }

      formStep3.classList.remove("d-none");
    } catch (error) {
      bodyModalMessage.innerText = "Ha ocurrido un error al enviar las respuestas, por favor vuelva e intente más tarde.";
      loading.classList.remove("active");
      formStep3.classList.remove("d-none");
      openModal("modalrecover");
    }
  }

  async function fetchData(url = "", params = {}) {
    try {
      const response = await fetch(url, {
        method: "POST",
        headers: headers(),
        body: JSON.stringify(params),
      });
      const data = await response.json();
      return data;
    } catch (error) {
      return {
        codigo: "000",
        message: "Ha ocurrido un error al realizar la petición",
        status: 500,
        error: true,
      };
    }
  }
</script>
