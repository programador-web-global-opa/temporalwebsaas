      </div>

      <img src="/images/personas.png" class="app-image-login-two" alt="login" />
      <img src="/images/persona.png" class="app-image-login-one" alt="login" />
      </div>
     </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
