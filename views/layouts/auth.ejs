      <p class="app-title-service">Servicios <b>EN LÍNEA</b></p>
      <div class="app-section">
        <img src="/images/fondo.png" class="fondo" />
        <div class="cuadro"></div>
        <div class="mini">
          <!-- SVG -->
          <svg
            id="Capa_1"
            xmlns="http://www.w3.org/2000/svg"
            version="1.1"
            viewBox="0 0 512 512"
            class="icon"
            fill="#000000"
          >
            <path
